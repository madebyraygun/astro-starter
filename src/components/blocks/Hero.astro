---
import Picture from "../Picture.astro";
const { eyebrow, headline, image, alt, caption, imagePosition, ratio, background } = Astro.props;
---
<section
  class:list={[
    "block-hero",
    imagePosition && `image-${imagePosition}`,
    ratio && `ratio-${ratio}`,
  ]}
>
  <div class:list={["hero-panel", background && `block-bg-${background}`]}>
    {eyebrow && <p class="block-heading is-eyebrow hero-eyebrow">{eyebrow}</p>}
    {headline && <h2 class="block-heading is-display hero-headline">{headline}</h2>}
  </div>
  <figure class="hero-media">
    {image && <Picture src={image} alt={alt ?? ""} sizes="(max-width: 760px) 100vw, 60vw" />}
    {caption && <figcaption>{caption}</figcaption>}
  </figure>
</section>
