---
import { picture, DEFAULT_WIDTHS } from "../lib/images";

interface Props {
  src: string | null | undefined;
  alt?: string;
  sizes?: string;
  widths?: number[];
}

const { src, alt = "", sizes = "(max-width: 760px) 100vw, 720px", widths = DEFAULT_WIDTHS } = Astro.props;
const pic = await picture(src, widths);
---

{
  pic ? (
    <picture>
      {pic.sources.map((s) => (
        <source type={s.type} srcset={s.srcset} sizes={sizes} />
      ))}
      <img
        src={pic.fallback.src}
        width={pic.fallback.width}
        height={pic.fallback.height}
        alt={alt}
        loading="lazy"
        decoding="async"
      />
    </picture>
  ) : (
    src && <img src={src} alt={alt} loading="lazy" decoding="async" />
  )
}
